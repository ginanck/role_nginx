{#- jinja2: lstrip_blocks: true, trim_blocks: true -#}
# {{ ansible_managed }}

{% for server in nginx_default_server %}
{% if server.enabled %}
server {
{% for listen in server.listen %}
    listen       {% if listen.ip is defined and listen.ip %}{{ listen.ip }}:{% endif %}{{ listen.port }}       {% if listen.ssl is defined and listen.ssl %}ssl{% endif %} {% if listen.http2 is defined and listen.http2 %}http2{% endif %} {{ listen.name }};
{% if listen.ipv6 is defined %}
    listen       {% if listen.ipv6 is defined and listen.ipv6 %}{{ listen.ipv6 }}:{% endif %}{{ listen.port }}  {% if listen.ssl is defined and listen.ssl %}ssl{% endif %} {% if listen.http2 is defined and listen.http2 %}http2{% endif %} {{ listen.name }};
{% endif %}
{% endfor %}
    server_name  {{ server.server_name | default('_') }};
    root         {{ server.root }};

{% if server.tls is defined %}
    ssl_certificate             {{ server.tls.ssl_certificate }};
    ssl_certificate_key         {{ server.tls.ssl_certificate_key }};
    ssl_session_cache           {{ server.tls.ssl_session_cache }};
    ssl_session_timeout         {{ server.tls.ssl_session_timeout }};
    ssl_ciphers                 {{ server.tls.ssl_ciphers }};
    ssl_prefer_server_ciphers   {{ server.tls.ssl_prefer_server_ciphers }};
{% endif %}

{% for location in server.locations %}
    location {{ location.path }} {
{% for conf in location.config %}
        {{ conf }}
{% endfor %}
    }

{% endfor %}

{% for error in server.error_pages %}
    error_page {% for code in error.codes %}{{ code }}{% if not loop.last %} {% endif %}{% endfor %} {{ error.page }};
        location = {{ error.page }} {
    }

{% endfor %}
}
{% endif %}

{% endfor %}
