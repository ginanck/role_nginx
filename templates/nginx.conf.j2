{#- jinja2: lstrip_blocks: true, trim_blocks: true -#}
# {{ ansible_managed }}

# For more information on configuration, see:
#   * Official English Documentation: http://nginx.org/en/docs/
#   * Official Russian Documentation: http://nginx.org/ru/docs/

user                {{ nginx_service_user | default('root') }};
worker_processes    {{ nginx_service_worker_processes }};
error_log           {{ nginx_service_error_log }};
pid                 {{ nginx_service_pid }};

# Load dynamic modules. See /usr/share/doc/nginx/README.dynamic.
include /usr/share/nginx/modules/*.conf;

events {
    worker_connections {{ nginx_service_worker_connections }};
}

{% if nginx_default_server or nginx_vhost_servers or nginx_static_file_servers or nginx_http_loadbalancers %}
# Include HTTP configuration for Default Server/VHost and Static file servers
include {{ nginx_service_config_path }}/http.conf;
{% endif %}

{% if nginx_stream_loadbalancers %}
# Include Stream configuration for TCP/UDP load balancers
include {{ nginx_service_config_path }}/stream.conf;
{% endif %}
